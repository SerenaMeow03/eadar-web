<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Eadartrans (Wuhan) Co., Ltd. - Professional Translation & Localization Services</title>
    <meta name="description" content="Eadartrans provides professional translation, interpretation, and localization services covering 50+ languages for global clients.">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary: #648dc9;
            --primary-light: #648dc9;
            --accent: #648dc9;
            --text-dark: #1a1a1a;
            --text-gray: #666666;
            --text-light: #999999;
            --bg-white: #ffffff;
            --bg-light: #f8f9fa;
            --border: #e8e8e8;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
            line-height: 1.6;
            color: var(--text-dark);
            background: var(--bg-white);
        }

        /* Navigation */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(255,255,255,0.98);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            z-index: 1000;
            transition: all 0.3s;
        }

        .nav-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
            height: 80px;
        }

        .logo {
            display: flex;
            align-items: center;
            text-decoration: none;
            height: 80px;
        }

        .logo img {
            height: 80px;
            display: block;
            padding: 0;
            margin: 0;
            width: auto;
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 40px;
            margin-left: auto;
            margin-right: 40px;
            align-items: center;
            height: 80px;
        }

        .nav-menu a {
            color: var(--text-dark);
            text-decoration: none;
            font-size: 15px;
            font-weight: 500;
            transition: color 0.3s;
            position: relative;
        }

        .nav-menu a:hover,
        .nav-menu a.active {
            color: var(--primary);
        }

        .nav-menu a::after {
            content: '';
            position: absolute;
            bottom: -5px;
            left: 0;
            width: 0;
            height: 2px;
            background: var(--primary);
            transition: width 0.3s;
        }

        .nav-menu a:hover::after,
        .nav-menu a.active::after {
            width: 100%;
        }

        .lang-switcher {
            display: flex;
            gap: 12px;
            align-items: center;
            padding-right: 40px;
            height: 80px;
        }

        .lang-btn {
            padding: 8px 16px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.3s;
            border: 1px solid var(--border);
            color: var(--text-gray);
        }

        .lang-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }

        .lang-btn:hover:not(.active) {
            border-color: var(--primary);
            color: var(--primary);
        }

        /* Hero Section */
        .hero {
            min-height: 100vh;
            align-items: center;
            padding: 120px 40px 80px;
            background: linear-gradient(135deg, #f8fafc 0%, #e8f4f8 100%);
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 80%;
            height: 200%;
            background: radial-gradient(ellipse, rgba(74,144,164,0.08) 0%, transparent 70%);
            pointer-events: none;
        }

        .hero-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
            width: 100%;
        }

        .hero-content h1 {
            font-size: 52px;
            font-weight: 700;
            line-height: 1.2;
            color: var(--text-dark);
            margin-bottom: 24px;
        }

        .hero-content h1 span {
            color: var(--primary);
        }

        .hero-subtitle {
            font-size: 20px;
            color: var(--text-gray);
            margin-bottom: 40px;
            line-height: 1.8;
        }

        .hero-buttons {
            gap: 20px;
        }

        .btn {
            padding: 16px 36px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
            font-size: 16px;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 10px;
        }

        .btn-primary {
            background: var(--primary);
            color: white;
            box-shadow: 0 4px 20px rgba(30,58,95,0.3);
        }

        .btn-primary:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
            box-shadow: 0 6px 30px rgba(30,58,95,0.4);
        }

        .btn-outline {
            background: transparent;
            color: var(--primary);
            border: 2px solid var(--primary);
        }

        .btn-outline:hover {
            background: var(--primary);
            color: white;
        }

        .hero-stats {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 30px;
        }

        .stat-card {
            background: white;
            padding: 32px;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.06);
            text-align: center;
            transition: transform 0.3s;
        }

        .stat-card:hover {
            transform: translateY(-5px);
        }

        .stat-number {
            font-size: 42px;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 8px;
        }

        .stat-label {
            font-size: 14px;
            color: var(--text-gray);
        }

        /* Stats Section */
        .stats-section {
            background: var(--primary);
            padding: 60px 40px;
        }

        .stats-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            text-align: center;
        }

        .stat-item {
            color: white;
        }

        .stat-item .number {
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .stat-item .label {
            font-size: 16px;
            opacity: 0.9;
        }

        /* Services Section */
        .services {
            padding: 100px 40px;
            background: var(--bg-white);
        }

        .section-header {
            max-width: 1280px;
            margin: 0 auto 60px;
            text-align: center;
        }

        .section-header h2 {
            font-size: 40px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 16px;
        }

        .section-header p {
            font-size: 18px;
            color: var(--text-gray);
            max-width: 600px;
            margin: 0 auto;
        }

        .services-grid {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .service-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 40px 32px;
            transition: all 0.3s;
            cursor: pointer;
        }

        .service-card:hover {
            border-color: var(--primary);
            box-shadow: 0 10px 40px rgba(30,58,95,0.1);
            transform: translateY(-5px);
        }

        .service-icon {
            width: 64px;
            height: 64px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
            border-radius: 12px;
            margin-bottom: 24px;
            color: white;
            font-size: 28px;
        }

        .service-card h3 {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 12px;
            color: var(--text-dark);
        }

        .service-card p {
            font-size: 15px;
            color: var(--text-gray);
            line-height: 1.7;
        }

        .service-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            margin-top: 20px;
            color: var(--primary);
            text-decoration: none;
            font-weight: 600;
            font-size: 14px;
            transition: gap 0.3s;
        }

        .service-card:hover .service-link {
        }

        /* Languages Section */
        .languages {
            padding: 100px 40px;
            background: var(--bg-light);
        }

        .languages-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 80px;
            align-items: center;
        }

        .languages-content h2 {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--text-dark);
        }

        .languages-content p {
            font-size: 16px;
            color: var(--text-gray);
            line-height: 1.8;
            margin-bottom: 32px;
        }

        .languages-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        .language-tag {
            background: white;
            padding: 16px 20px;
            border-radius: 8px;
            border: 1px solid var(--border);
            font-size: 14px;
            color: var(--text-dark);
            transition: all 0.3s;
        }

        .language-tag:hover {
            border-color: var(--primary);
            background: var(--bg-white);
        }

        .language-tag i {
            color: var(--accent);
            margin-right: 8px;
        }

        /* Industries Section */
        .industries {
            padding: 100px 40px;
            background: var(--bg-white);
        }

        .industries-grid {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 24px;
        }

        .industry-card {
            background: var(--bg-light);
            padding: 32px 24px;
            border-radius: 12px;
            text-align: center;
            transition: all 0.3s;
            border: 1px solid transparent;
        }

        .industry-card:hover {
            background: white;
            border-color: var(--primary);
            box-shadow: 0 8px 30px rgba(30,58,95,0.1);
        }

        .industry-icon {
            font-size: 36px;
            color: var(--primary);
            margin-bottom: 16px;
        }

        .industry-card h4 {
            font-size: 16px;
            font-weight: 600;
            color: var(--text-dark);
        }

        /* Testimonials */
        .testimonials {
            padding: 100px 40px;
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
        }

        .testimonials .section-header h2,
        .testimonials .section-header p {
            color: white;
        }

        .testimonials-grid {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
        }

        .testimonial-card {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            padding: 40px;
            border-radius: 16px;
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
        }

        .testimonial-card .quote {
            font-size: 16px;
            line-height: 1.8;
            margin-bottom: 24px;
            font-style: italic;
        }

        .testimonial-author {
            align-items: center;
            gap: 16px;
        }

        .author-avatar {
            width: 48px;
            height: 48px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            font-weight: 600;
        }

        .author-info h5 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 4px;
        }

        .author-info span {
            font-size: 14px;
            opacity: 0.8;
        }

        /* CTA Section */
        .cta-section {
            padding: 100px 40px;
            background: var(--bg-light);
            text-align: center;
        }

        .cta-container {
            max-width: 800px;
            margin: 0 auto;
        }

        .cta-section h2 {
            font-size: 40px;
            font-weight: 700;
            margin-bottom: 20px;
            color: var(--text-dark);
        }

        .cta-section p {
            font-size: 18px;
            color: var(--text-gray);
            margin-bottom: 40px;
        }

        /* Footer */
        .footer {
            background: var(--primary);
            color: white;
            padding: 80px 40px 40px;
        }

        .footer-container {
            max-width: 1280px;
            margin: 0 auto;
            display: grid;
            grid-template-columns: 3fr 1fr 1fr 2fr;
            gap: 60px;
            margin-bottom: 60px;
        }

        .footer-brand img {
            height: 50px;
            margin-bottom: 20px;
        }

        .footer-brand p {
            font-size: 15px;
            line-height: 1.8;
            opacity: 0.8;
            margin-bottom: 24px;
        }

        .footer-social {
            display: flex;
            gap: 16px;
        }

        .footer-social a {
            width: 40px;
            height: 40px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            color: white;
            text-decoration: none;
            transition: all 0.3s;
        }

        .footer-social a:hover {
            background: rgba(255,255,255,0.2);
            transform: translateY(-3px);
        }

        .footer-column h4 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 24px;
        }

        .footer-column ul {
            list-style: none;
        }

        .footer-column li {
            margin-bottom: 12px;
        }

        .footer-column a {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s;
        }

        .footer-column a:hover {
            color: white;
        }

        .footer-bottom {
            max-width: 1280px;
            margin: 0 auto;
            padding-top: 40px;
            border-top: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 14px;
            opacity: 0.8;
        }

        /* Responsive */
        @media (max-width: 1024px) {
            .hero-container {
                grid-template-columns: 1fr;
                gap: 60px;
            }

            .services-grid,
            .testimonials-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .industries-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .stats-container {
                grid-template-columns: repeat(2, 1fr);
            }

            .footer-container {
                grid-template-columns: repeat(2, 1fr);
            }

            .languages-container {
                grid-template-columns: 1fr;
            }
        }

        @media (max-width: 768px) {
            .nav-menu {
                display: none;
            }

            .hero-content h1 {
                font-size: 36px;
            }

            .hero-stats {
                grid-template-columns: 1fr;
            }

            .services-grid,
            .testimonials-grid,
            .industries-grid,
            .stats-container {
                grid-template-columns: 1fr;
            }

            .footer-container {
                grid-template-columns: 1fr;
                gap: 40px;
            }

            .footer-bottom {
                flex-direction: column;
                gap: 20px;
                text-align: center;
            }
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="index.html" class="logo">
                <img src="../images/logo-blue.png" alt="Eadartrans">
            </a>
            <ul class="nav-menu">
                <li><a href="index.html" class="active">Home</a></li>
                <li><a href="about.html">About Us</a></li>
                <li><a href="contact.html">Services</a></li>
                <li><a href="news.html">News</a></li>
                <li><a href="contact.html">Contact</a></li>
            </ul>
            <div class="lang-switcher">
                <a href="../index.html" class="lang-btn">中文</a>
                <a href="index.html" class="lang-btn active">EN</a>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero">
        <div class="hero-container">
            <div class="hero-content">
                <h1>Connecting Global Markets<br><span>Through Language Services</span></h1>
                <p class="hero-subtitle">Eadartrans is committed to helping clients break down language barriers and accurately communicate product information, supporting your global expansion. With nearly a decade of industry experience, we cover 50+ languages.</p>
                <div class="hero-buttons">
                    <a href="contact.html" class="btn btn-primary">
                        <i class="fas fa-arrow-right"></i>
                        Explore Our Services
                    </a>
                    <a href="contact.html" class="btn btn-outline">Contact Us</a>
                </div>
            </div>
            <div class="hero-stats">
                <div class="stat-card">
                    <div class="stat-number">10+</div>
                    <div class="stat-label">Years Experience</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">50+</div>
                    <div class="stat-label">Languages</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">1000+</div>
                    <div class="stat-label">Clients</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">99%</div>
                    <div class="stat-label">Satisfaction</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Stats Section -->
    <section class="stats-section">
        <div class="stats-container">
            <div class="stat-item">
                <div class="number">5M+</div>
                <div class="label">Words Translated Annually</div>
            </div>
            <div class="stat-item">
                <div class="number">500M+</div>
                <div class="label">Total Words Translated</div>
            </div>
            <div class="stat-item">
                <div class="number">30%</div>
                <div class="label">Annual Growth Rate</div>
            </div>
            <div class="stat-item">
                <div class="number">20+</div>
                <div class="label">Industries Served</div>
            </div>
        </div>
    </section>

    <!-- Services Section -->
    <section class="services">
        <div class="section-header">
            <h2>Our Services</h2>
            <p>Comprehensive language solutions to power your globalization strategy</p>
        </div>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-file-alt"></i>
                </div>
                <h3>Document Translation</h3>
                <p>Professional translation of contracts, technical documents, academic papers, ensuring accurate terminology and standardized formatting.</p>
                <a href="contact.html" class="service-link">
                    Get Quote <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-microphone"></i>
                </div>
                <h3>Interpretation</h3>
                <p>Simultaneous, consecutive, and escort interpretation for conferences, business negotiations, exhibitions, and various professional settings.</p>
                <a href="contact.html" class="service-link">
                    Get Quote <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-globe"></i>
                </div>
                <h3>Localization</h3>
                <p>Website, software, and game localization to help your products seamlessly enter global markets and achieve true native experiences.</p>
                <a href="contact.html" class="service-link">
                    Get Quote <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-certificate"></i>
                </div>
                <h3>Certified Translation</h3>
                <p>Notarized and certified translation services for immigration, study abroad, and business purposes with legal validity.</p>
                <a href="contact.html" class="service-link">
                    Get Quote <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-laptop-code"></i>
                </div>
                <h3>Multimedia Localization</h3>
                <p>Video subtitling, dubbing, and audio transcription to make multimedia content effective in any language.</p>
                <a href="contact.html" class="service-link">
                    Get Quote <i class="fas fa-arrow-right"></i>
                </a>
            </div>
            <div class="service-card">
                <div class="service-icon">
                    <i class="fas fa-brain"></i>
                </div>
                <h3>AI Data Services</h3>
                <p>High-quality data annotation and corpus building for AI applications, powering the development of AI technology.</p>
                <a href="contact.html" class="service-link">
                    Get Quote <i class="fas fa-arrow-right"></i>
                </a>
            </div>
        </div>
    </section>

    <!-- Languages Section -->
    <section class="languages">
        <div class="languages-container">
            <div class="languages-content">
                <h2>Global Language Coverage</h2>
                <p>Our multilingual services cover major markets worldwide, including Europe, Asia, and the Americas, helping your products connect with global audiences.</p>
                <a href="contact.html" class="btn btn-primary">
                    <i class="fas fa-globe"></i>
                    View All Languages
                </a>
            </div>
            <div class="languages-grid">
                <div class="language-tag"><i class="fas fa-check-circle"></i> English</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Japanese</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Korean</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> German</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> French</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Spanish</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Russian</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Italian</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Portuguese</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Arabic</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Thai</div>
                <div class="language-tag"><i class="fas fa-check-circle"></i> Vietnamese</div>
            </div>
        </div>
    </section>

    <!-- Industries Section -->
    <section class="industries">
        <div class="section-header">
            <h2>Industries We Serve</h2>
            <p>Deep expertise across multiple verticals with professional industry solutions</p>
        </div>
        <div class="industries-grid">
            <div class="industry-card">
                <div class="industry-icon"><i class="fas fa-balance-scale"></i></div>
                <h4>Legal</h4>
            </div>
            <div class="industry-card">
                <div class="industry-icon"><i class="fas fa-heartbeat"></i></div>
                <h4>Life Sciences</h4>
            </div>
            <div class="industry-card">
                <div class="industry-icon"><i class="fas fa-laptop"></i></div>
                <h4>Software & IT</h4>
            </div>
